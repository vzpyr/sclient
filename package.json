{
  "name": "sclient",
  "desktopName": "com.vzpyr.sclient.desktop",
  "version": "0.1.0",
  "description": "Customizable cross-platform desktop client for SoundCloud",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --windows",
    "postinstall": "electron-builder install-app-deps",
    "format": "prettier --write ."
  },
  "build": {
    "appId": "com.vzpyr.sclient",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "productName": "SClient",
    "electronVersion": "43.0.0+wvcus",
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/",
      "customDir": "v43.0.0+wvcus"
    },
    "directories": {
      "buildResources": "icons"
    },
    "asarUnpack": [
      "node_modules/youtube-dl-exec/**",
      "node_modules/better-sqlite3/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "flatpak",
        "rpm"
      ],
      "category": "AudioVideo",
      "syncDesktopName": true,
      "executableName": "sclient",
      "desktop": {
        "entry": {
          "Name": "SClient"
        }
      }
    },
    "flatpak": {
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "25.08",
      "sdk": "org.freedesktop.Sdk",
      "finishArgs": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--share=network",
        "--device=dri",
        "--filesystem=xdg-download",
        "--filesystem=xdg-run/discord-ipc-0",
        "--filesystem=xdg-run/discord-ipc-1",
        "--filesystem=xdg-run/discord-ipc-2",
        "--filesystem=xdg-run/app/com.discordapp.Discord:ro",
        "--filesystem=xdg-run/app/com.discordapp.DiscordCanary:ro",
        "--filesystem=xdg-run/app/com.discordapp.DiscordPTB:ro",
        "--filesystem=xdg-run/snap.discord:ro",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=org.freedesktop.Notifications",
        "--own-name=org.mpris.MediaPlayer2.chromium",
        "--own-name=org.mpris.MediaPlayer2.chromium.*"
      ],
      "files": [
        [
          "com.vzpyr.sclient.metainfo.xml",
          "/share/metainfo/com.vzpyr.sclient.metainfo.xml"
        ]
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${os}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  },
  "author": "vzpyr <vzpyr@example.com>",
  "homepage": "https://github.com/vzpyr/sclient",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v43.0.0+wvcus",
    "electron-builder": "^26.15.3",
    "prettier": "^3.9.5"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "@xhayper/discord-rpc": "^1.3.4",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.5.1",
    "cross-fetch": "^4.1.0",
    "youtube-dl-exec": "^3.1.9"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron-winstaller@5.4.0": true,
    "youtube-dl-exec@3.1.9": true
  }
}
